{
  "name": "BOOK_EXAMPLE",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "9.9.1",
    "@sap/cds-common-content": "^3.2.0",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.0",
    "randexp": "^0.5.3"
  },
  "cds": {
    "i18n": {
      "default_language": "de"
    },
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "agent1": {
            "password": "secret",
            "roles": [
              "agent"
            ],
            "attr": {
              "guid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa"
            }
          },
          "agent2": {
            "password": "secret",
            "roles": [
              "admin"
            ],
            "attr": {
              "guid": "bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb"
            }
          },
          "*": false
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "scripts": {
    "start": "cds-serve",
    "watch-agentapp": "cds watch --open com.example.incident.agentapp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/agentapp",
    "app/agentapp"
  ]
}
